        hover.style.display = "block";
        const rect = el.getBoundingClientRect();
        hover.style.left = rect.left + "px";
        hover.style.top = rect.top + "px";
        hover.style.width = rect.width + "px";
        hover.style.height = rect.height + "px";

        info.textContent = el.tagName.toLowerCase() + (el.id ? ` #${el.id}` : "");
    };

    const click = (e) => {
        const el = e.target;
        if (!el || el.closest("#ghost-ui-root") || el.closest("#ghost-inspector")) return;

        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();

        currentElement = el;
        editor.value = el.outerHTML;
        showNotification("Elemento carregado no editor.");
    };

    document.addEventListener("mousemove", move, true);
    document.addEventListener("click", click, true);

    // Botão Aplicar Alterações
    panel.querySelector("#ghost-inspector-apply").onclick = () => {
        if (!currentElement) {
            showNotification("Nenhum objeto selecionado para salvar.");
            return;
        }
        try {
            const temp = document.createElement("div");
            temp.innerHTML = editor.value.trim();
            const newElement = temp.firstElementChild;

            if (!newElement) {
                showNotification("Código HTML inválido.");
                return;
            }

            currentElement.replaceWith(newElement);
            currentElement = newElement; // Atualiza a referência
            showNotification("HTML modificado com sucesso!");
        } catch (err) {
            console.error(err);
            showNotification("Erro de sintaxe ao modificar o elemento.");
        }
    };

    // Botão Fechar Painel
    panel.querySelector("#ghost-inspector-close").onclick = () => {
        document.removeEventListener("mousemove", move, true);
        document.removeEventListener("click", click, true);
        hover.remove();
        panel.remove();
        showNotification("Inspector encerrado.");
    };

    // Sistema de Arrastar o Painel (Drag and Drop)
    let drag = false;
    let offsetX = 0, offsetY = 0;
    const header = panel.querySelector("#ghost-inspector-header");

    header.onmousedown = (e) => {
        if (e.target.id === "ghost-inspector-close") return;
        drag = true;
        offsetX = e.clientX - panel.offsetLeft;
        offsetY = e.clientY - panel.offsetTop;
    };

    document.addEventListener("mousemove", (e) => {
        if (!drag) return;
        panel.style.left = (e.clientX - offsetX) + "px";
        panel.style.top = (e.clientY - offsetY) + "px";
        panel.style.right = "auto";
    });

    document.addEventListener("mouseup", () => drag = false);
    showNotification("Modo Inspeção ativado. Selecione um elemento da página.");
};

