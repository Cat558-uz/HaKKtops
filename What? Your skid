(() => {
    'use strict';

    // --- Bloqueador de Alertas / Modais do Bloxd.io ---
    // Isso impede que o jogo jogue notificações pop-up irritantes na tela enquanto você digita ou joga
    const blockAlerts = () => {
        try {
            window.alert = function() { return true; };
            window.confirm = function() { return true; };
            window.prompt = function() { return null; };
            if (window.unsafeWindow) {
                window.unsafeWindow.alert = function() { return true; };
                window.unsafeWindow.confirm = function() { return true; };
                window.unsafeWindow.prompt = function() { return null; };
            }
        } catch(e) {}
    };
    blockAlerts();
    window.addEventListener('DOMContentLoaded', blockAlerts);

    const UPDATE_URL = "https://raw.githubusercontent.com/Cat558-uz/Bloxd.io-Hack/main/message.txt";
    const CURRENT_VERSION = "3.1.0";

    // Estado global da interface
    const state = {
        binds: {},
        listening: null,
        minimized: false,
        visible: true,
        tab: "home",
        dropdowns: {}
    };

    let clickCount = 0;

    // --- Sistema de Estilos Premium (Minimalista: Preto, Cinza e Branco) ---
    const style = document.createElement("style");
    style.textContent = `
        :root {
            --bg-main: rgba(10, 10, 10, 0.98);
            --bg-sec: rgba(255, 255, 255, 0.04);
            --bg-sec-hover: rgba(255, 255, 255, 0.1);
