            transition: background 0.15s;
        }

        .dropdown-trigger:hover { background: var(--bg-sec-hover); }

        .dropdown-menu {
            display: none;
            flex-direction: column;
            background: #0a0a0a;
            border: 1px solid var(--border);
            border-radius: 6px;
            margin-top: 4px;
            overflow: hidden;
            z-index: 10;
        }

