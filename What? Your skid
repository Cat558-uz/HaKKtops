            height: 10px;
            border-radius: 50%;
            background: var(--text);
            cursor: pointer;
        }

        .bind-btn {
            padding: 4px 8px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 4px;
            font-size: 11px;
            font-weight: bold;
            cursor: pointer;
            min-width: 60px;
            text-align: center;
        }

        .bind-btn.active {
            background: #ffffff;
            color: #000000;
        }

        #ui-resizer {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 12px;
            height: 12px;
