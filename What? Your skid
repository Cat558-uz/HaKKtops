        // Desativa a edição
        document.body.contentEditable = "false";

        // Remove o efeito visual
        const oldStyle = document.getElementById("ghost-edit-style");
        if (oldStyle) oldStyle.remove();

        showNotification("Modo Edição DESATIVADO. Alterações salvas no navegador.");
    }
};

