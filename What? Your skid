// --- FUNÇÃO: CLIQUE PARA DELETAR ---
const startDeleteMode = () => {
    if (window.ghostDeleteMode) return;
    window.ghostDeleteMode = true;

    // Remove overlay antigo se existir
    const oldOverlay = document.getElementById("ghost-delete-overlay");
    if (oldOverlay) oldOverlay.remove();

    const overlay = document.createElement("div");
    overlay.id = "ghost-delete-overlay";
    overlay.style.cssText = `
        position: fixed; background: #ff2d2d; color: #fff; padding: 6px 10px;
        border-radius: 6px; font-size: 11px; pointer-events: none; z-index: 999999999;
        font-family: monospace; box-shadow: 0 10px 25px rgba(0,0,0,0.5); display: none;
    `;
    document.body.appendChild(overlay);

    const move = (e) => {
        const el = e.target;
        // Evita selecionar a própria interface do editor
        if (!el || el.closest("#ghost-ui-root") || el.closest("#ghost-inspector")) {
            overlay.style.display = "none";
            return;
        }
        overlay.style.display = "block";
        overlay.style.left = (e.clientX + 14) + "px";
        overlay.style.top = (e.clientY + 14) + "px";
        overlay.textContent = el.tagName.toLowerCase() + (el.id ? ` #${el.id}` : "");
    };

    const click = (e) => {
        const el = e.target;
        if (!el || el.closest("#ghost-ui-root") || el.closest("#ghost-inspector")) return;

        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();

        try {
            el.remove();
            showNotification("Objeto deletado com sucesso.");
        } catch (err) {
            console.error(err);
            showNotification("Erro ao deletar objeto.");
        }
        stop();
    };

    const stop = () => {
        window.ghostDeleteMode = false;
        document.removeEventListener("mousemove", move, true);
        document.removeEventListener("click", click, true);
        overlay.remove();
    };

    document.addEventListener("mousemove", move, true);
    document.addEventListener("click", click, true);
    showNotification("Modo Remoção: Clique em um elemento para deletá-lo.");
};

