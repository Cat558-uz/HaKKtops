        // --- ABA VISUAL / CONTROLE DE TELA (FOCO EM PREPARO PvP E EDIÇÃO VISUAL) ---
        if (state.tab === "main") {
            const secFiltros = addSection("Controle e Ajustes Visuais", content);
            
            addButton("Inverter Cores (Modo Noturno Forçado)", secFiltros, () => {
                const html = document.documentElement;
                html.style.filter = html.style.filter === "invert(1)" ? "none" : "invert(1)";
                showNotification("Filtro Aplicado");
            });

            addButton("Alternar Mira Central Fixo (Crosshair)", secFiltros, () => {
                let crosshair = document.getElementById("ghost-crosshair");
                if (crosshair) {
                    crosshair.remove();
                    showNotification("Mira Removida");
                } else {
                    crosshair = document.createElement("div");
                    crosshair.id = "ghost-crosshair";
                    // Mira simples e discreta (ponto verde brilhante centralizado)
                    crosshair.style = "position:fixed; top:50%; left:50%; width:6px; height:6px; background:#00ff00; border-radius:50%; border:1px solid #000; z-index:10000000; pointer-events:none; transform:translate(-50%, -50%); box-shadow: 0 0 4px #00ff00;";
                    document.body.appendChild(crosshair);
                    showNotification("Mira Estática PvP Ativada!");
                }
            });

            addButton("Modo Otimizar Latência (Remover Animações)", secFiltros, () => {
                let styleStyle = document.getElementById("ghost-latency-tweak");
                if (styleStyle) {
                    styleStyle.remove();
                    showNotification("Otimização Desativada");
                } else {
                    styleStyle = document.createElement("style");
                    styleStyle.id = "ghost-latency-tweak";
                    styleStyle.innerHTML = "*, *::before, *::after { transition: none !important; animation-duration: 0s !important; scroll-behavior: auto !important; }";
                    document.body.appendChild(styleStyle);
                    showNotification("Transições removidas! FPS focado na renderização bruta.");
                }
            });

            // --- SEÇÃO DOS INCREMENTOS DE PvP: AUTO CLICKER ---
            const secPvP = addSection("Ajustes Avançados de Macro/PvP", content);

            addButton(autoClickerActive ? "Desativar Auto Clicker [Ativo]" : "Ativar Auto Clicker", secPvP, () => {
                if (autoClickerActive) {
                    clearInterval(autoClickerInterval);
                    autoClickerActive = false;
                    showNotification("Auto Clicker Desativado");
                } else {
                    autoClickerActive = true;
                    autoClickerInterval = setInterval(() => {
                        // Simula um disparo de clique nativo do mouse esquerdo na posição atual do cursor
                        const el = document.elementFromPoint(window.innerWidth / 2, window.innerHeight / 2) || document.body;
                        el.dispatchEvent(new MouseEvent("click", { bubbles: true, cancelable: true, view: window }));
                    }, 1000 / autoClickerCPS);
                    showNotification(`Auto Clicker Ligado! (${autoClickerCPS} CPS constante)`);
                }
                render();
            });

            addSlider("Velocidade do Auto Clicker (CPS)", 5, 30, autoClickerCPS, secPvP, (val) => {
                autoClickerCPS = val;
                if (autoClickerActive) {
                    // Reinicia o intervalo para atualizar o CPS dinamicamente se estiver ativo
                    clearInterval(autoClickerInterval);
                    autoClickerInterval = setInterval(() => {
                        const el = document.elementFromPoint(window.innerWidth / 2, window.innerHeight / 2) || document.body;
                        el.dispatchEvent(new MouseEvent("click", { bubbles: true, cancelable: true, view: window }));
                    }, 1000 / autoClickerCPS);
                }
            });

            // --- CONTROLES DE ESCALA DOS HUDS (Ajustar Tamanho) ---
            const secScales = addSection("Ajustar Tamanho dos Elementos", content);

            addSlider("Tamanho do HUD (WASD + Clicks)", 50, 200, Math.round(hudScale * 100), secScales, (val) => {
                hudScale = val / 100;
                const wasdBox = document.getElementById("ghost-wasd-hud");
                if (wasdBox) {
                    wasdBox.style.transform = `scale(${hudScale})`;
                }
            });

            addSlider("Tamanho do Contador de FPS", 50, 200, Math.round(fpsScale * 100), secScales, (val) => {
                fpsScale = val / 100;
                const fpsBox = document.getElementById("ghost-fps-counter");
                if (fpsBox) {
                    fpsBox.style.transform = `scale(${fpsScale})`;
                }
            });

            addSlider("Opacidade do Menu Principal", 30, 100, 98, secFiltros, (val) => {
                root.style.setProperty('--bg-main', `rgba(10, 10, 10, ${val / 100})`);
            });
        }
    };

    // --- Escuta de Teclas para o HUD WASD Estilizado ---
    document.addEventListener("keydown", (e) => {
        const key = e.key.toUpperCase();
        if (["W", "A", "S", "D"].includes(key)) {
            const el = document.getElementById(`wasd-${key}`);
            if (el) {
                el.style.background = "#ffffff";
                el.style.color = "#000000";
            }
        }
    });

    document.addEventListener("keyup", (e) => {
        const key = e.key.toUpperCase();
        if (["W", "A", "S", "D"].includes(key)) {
            const el = document.getElementById(`wasd-${key}`);
            if (el) {
                el.style.background = "rgba(255,255,255,0.04)";
                el.style.color = "var(--text-dim)";
            }
        }
    });
    
    
    // --- Controle de Abas e Janela ---
    tabs.forEach(t => {
        t.onclick = () => {
            tabs.forEach(x => x.classList.remove("active"));
            t.classList.add("active");
            state.tab = t.dataset.tab;
            render();
        };
    });

    root.querySelector("#min-btn").onclick = () => {
        state.minimized = !state.minimized;
        root.querySelector("#ui-body").style.display = state.minimized ? "none" : "flex";
        root.querySelector("#min-btn").textContent = state.minimized ? "+" : "−";
    };

    root.querySelector("#close-btn").onclick = () => {
        root.style.opacity = "0";
        root.style.transform = "scale(0.95)";
        setTimeout(() => root.remove(), 150);
    };

    // --- Sistema de Arrastar (Drag) ---
    let drag = false, ox = 0, oy = 0;
    header.onmousedown = (e) => {
        if (e.target.classList.contains('ctl-btn')) return;
        drag = true;
        ox = e.clientX - root.offsetLeft;
        oy = e.clientY - root.offsetTop;
    };
    document.addEventListener("mousemove", (e) => { if (drag) { root.style.left = `${e.clientX - ox}px`; root.style.top = `${e.clientY - oy}px`; } });
    document.addEventListener("mouseup", () => drag = false);

    // --- Redimensionamento (Resize) ---
    let resizing = false, startW = 0, startH = 0, startX = 0, startY = 0;
    root.querySelector("#ui-resizer").onmousedown = (e) => {
        e.preventDefault(); e.stopPropagation();
        resizing = true;
        startW = root.clientWidth; startH = root.clientHeight;
        startX = e.clientX; startY = e.clientY;
    };
    document.addEventListener("mousemove", (e) => {
        if (!resizing) return;
        root.style.width = `${startW + (e.clientX - startX)}px`;
        root.style.height = `${startH + (e.clientY - startY)}px`;
    });
    document.addEventListener("mouseup", () => resizing = false);

    // --- Verificação de Versão Limpa ---
    const checkUpdates = () => {
        if (typeof GM_xmlhttpRequest === "undefined") return;
        GM_xmlhttpRequest({
            method: "GET",
            url: UPDATE_URL,
            onload: (res) => {
                const match = res.responseText.match(/version\s*([\d.]+)/i);
                if (match && match[1]) {
                    const remoteVersion = match[1].trim();
                    if (remoteVersion !== CURRENT_VERSION) {
                        showNotification(`Update disponivel: v${remoteVersion}`);
                    }
                }
            }
        });
    };

    render();
    checkUpdates();
})();
