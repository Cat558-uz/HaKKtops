        } catch (err) {
            console.error(err);

            showNotification("Erro ao executar");
        }
    };

    box.querySelector("#ghost-clear").onclick = () => {
        box.querySelector("#ghost-editor").value = "";
    };

    box.querySelector("#ghost-executer-close").onclick = () => {
        box.remove();
    };

    showNotification("Executer aberto");
};

const startDeleteMode = () => {
    const overlay = document.createElement("div");

    overlay.style = `
        position:fixed;
        background:#ff0000;
        color:#fff;
        padding:6px 10px;
        border-radius:6px;
        font-size:11px;
        pointer-events:none;
        z-index:10000001;
        font-family:monospace;
        border:1px solid rgba(255,255,255,0.2);
    `;

    document.body.appendChild(overlay);

    const move = (e) => {
        const el = e.target;

        if (isGhostUI(el)) return;

        overlay.style.left = `${e.clientX + 14}px`;
        overlay.style.top = `${e.clientY + 14}px`;

        overlay.textContent =
            el.tagName.toLowerCase() +
            (el.id ? ` #${el.id}` : "");
    };

    const click = (e) => {
        const el = e.target;

        if (isGhostUI(el)) return;

        e.preventDefault();
        e.stopPropagation();

        el.remove();

        showNotification("Objeto deletado");

        stop();
    };

    const stop = () => {
        document.removeEventListener("mousemove", move, true);
        document.removeEventListener("click", click, true);

        overlay.remove();
    };

    document.addEventListener("mousemove", move, true);
    document.addEventListener("click", click, true);

    showNotification("Clique em um objeto");
};

const startInspectMode = () => {
    if (document.getElementById("ghost-inspector")) return;

    const panel = document.createElement("div");

    panel.id = "ghost-inspector";

    panel.style = `
        position:fixed;
        top:90px;
        right:20px;
        width:520px;
        height:620px;
        background:#050505;
        border:1px solid rgba(255,255,255,0.08);
        border-radius:12px;
        overflow:hidden;
        z-index:10000000;
        display:flex;
        flex-direction:column;
        box-shadow:0 30px 70px rgba(0,0,0,0.75);
        backdrop-filter:blur(12px);
    `;

    panel.innerHTML = `
        <div style="
            padding:12px;
            background:#0d0d0d;
            border-bottom:1px solid rgba(255,255,255,0.06);
            color:#fff;
            font-weight:bold;
            display:flex;
            justify-content:space-between;
            align-items:center;
            cursor:move;
            user-select:none;
        ">
            <span>Inspector</span>

            <button id="ghost-inspector-close" style="
                width:30px;
                height:30px;
                border:none;
                border-radius:6px;
                background:#ff4444;
                color:#fff;
                font-weight:bold;
                cursor:pointer;
            ">
                ×
            </button>
        </div>

        <div id="ghost-inspector-info" style="
            padding:10px 14px;
            background:#090909;
            border-bottom:1px solid rgba(255,255,255,0.05);
            color:#aaa;
            font-size:12px;
            font-family:monospace;
        ">
            Passe o mouse em um objeto
        </div>

        <textarea id="ghost-inspector-editor" spellcheck="false" style="
            flex:1;
            background:#030303;
            color:#fff;
            border:none;
            outline:none;
            resize:none;
            padding:14px;
            font-family:monospace;
            font-size:12px;
            line-height:1.5;
        "></textarea>

        <div style="
            display:flex;
            gap:10px;
            padding:12px;
            background:#0d0d0d;
            border-top:1px solid rgba(255,255,255,0.06);
        ">
            <button id="ghost-inspector-apply" style="
                flex:1;
                background:#fff;
                color:#000;
                border:none;
                padding:12px;
                border-radius:8px;
                font-weight:bold;
                cursor:pointer;
            ">
                Aplicar Alterações
            </button>
        </div>
    `;

    document.body.appendChild(panel);

    makeHUDDraggable(panel);

    let currentElement = null;

    const hover = document.createElement("div");

    hover.style = `
        position:fixed;
        border:2px solid #ffffff;
        background:rgba(255,255,255,0.03);
        pointer-events:none;
        z-index:10000001;
        border-radius:4px;
    `;

    document.body.appendChild(hover);

    const info =
        panel.querySelector("#ghost-inspector-info");

    const editor =
        panel.querySelector("#ghost-inspector-editor");

    const move = (e) => {
        const el = e.target;

        if (isGhostUI(el)) {
            hover.style.display = "none";
            return;
        }

        hover.style.display = "block";

        const rect = el.getBoundingClientRect();

        hover.style.left = rect.left + "px";
        hover.style.top = rect.top + "px";
        hover.style.width = rect.width + "px";
        hover.style.height = rect.height + "px";

        info.textContent =
            `${el.tagName.toLowerCase()} ${el.id ? "#" + el.id : ""}`;
    };

    const click = (e) => {
        const el = e.target;

        if (isGhostUI(el)) return;

        e.preventDefault();
        e.stopPropagation();

        currentElement = el;

        editor.value = el.outerHTML;

        showNotification("Objeto selecionado");
    };

    document.addEventListener("mousemove", move, true);
    document.addEventListener("click", click, true);

    panel.querySelector("#ghost-inspector-apply").onclick = () => {
        if (!currentElement) return;

        try {
            const temp = document.createElement("div");

            temp.innerHTML = editor.value;

            const newElement =
                temp.firstElementChild;

            if (!newElement) return;

            currentElement.replaceWith(newElement);

            currentElement = newElement;

            showNotification("Objeto atualizado");
        } catch {
            showNotification("Erro ao modificar");
        }
    };

    panel.querySelector("#ghost-inspector-close").onclick = () => {
        document.removeEventListener("mousemove", move, true);
        document.removeEventListener("click", click, true);

        hover.remove();

        panel.remove();

        showNotification("Inspector fechado");
    };

    showNotification("Inspector ativado");
};

