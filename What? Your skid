            gap: 12px;
        }

        .row span { font-size: 12px; }
        .row .val { color: var(--text); font-weight: bold; font-size: 11px; min-width: 28px; text-align: right;}

        .btn {
            width: 100%;
            padding: 10px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 6px;
